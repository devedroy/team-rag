# TeamRag environment configuration
# Copy this file to .env and fill in your values.

# --- Vector store (Qdrant) ---
# URL of the Qdrant HTTP API.
QDRANT_URL=http://localhost:6333

# Name of the Qdrant collection used to store document embeddings.
QDRANT_COLLECTION=teamrag

# --- Text Embeddings Inference (TEI) ---
# URL of the HuggingFace TEI server that produces embeddings.
TEI_URL=http://localhost:8080

# --- Relational database (PostgreSQL) ---
# Credentials used by the postgres Docker service and the connection URL below.
POSTGRES_USER=teamrag
POSTGRES_PASSWORD=teamrag
POSTGRES_DB=teamrag

# SQLAlchemy async connection string.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Note: DATABASE_URL must match POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB above.
# Update all four if you change credentials.
DATABASE_URL=postgresql+asyncpg://teamrag:teamrag@localhost:5432/teamrag

# --- Confluence connector ---
# Base URL of your Confluence instance (Cloud or Data Center).
CONFLUENCE_URL=https://your-org.atlassian.net

# Your Confluence login email.
CONFLUENCE_USERNAME=you@org.com

# Confluence API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens).
CONFLUENCE_API_TOKEN=your-token-here

# Comma-separated list of Confluence space keys to index.
CONFLUENCE_SPACE_KEYS=ENG,ARCH

# Maximum pages to fetch per CLI run (safety cap).
CONFLUENCE_MAX_PAGES=500

# --- GitHub connector ---
# Personal Access Token with "repo" read scope.
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Comma-separated list of repos to index (owner/repo format).
GITHUB_REPOS=org/repo1,org/repo2

# Maximum merged PRs to fetch per repo per CLI run (safety cap).
GITHUB_MAX_PRS=200

# --- Microsoft Teams chat ingest (Phase 6) ---
# Entra tenant id, app registration client id/secret, and the bot user's Azure AD object id (for joinedTeams).
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_BOT_USER_ID=

# --- Webex Messaging chat ingest (Phase 6) ---
# Bot access token and org id (metadata). WEBEX_WEB_CLIENT_BASE builds thread deep links.
WEBEX_BOT_TOKEN=
WEBEX_ORG_ID=
WEBEX_WEB_CLIENT_BASE=https://app.webex.com

# Shared Teams + Webex ingest tuning
# Seconds between runs when using: python -m teamrag.ingest teams|webex|chat --poll
CHAT_INGEST_POLL_INTERVAL_SECONDS=300
# Minimum distinct human authors (Teams channel sample) or human memberships (Webex room) before indexing threads there.
CHAT_INGEST_MIN_PARTICIPANTS=5
# If true, skip threads that are a single root message with no replies.
CHAT_INGEST_SKIP_NO_REPLIES=true
# Safety caps per channel / room per ingest run.
CHAT_INGEST_MAX_CHANNEL_ROOTS=200
CHAT_INGEST_WEBEX_MAX_MESSAGES=500

# --- LLM backend (for /v1/chat/completions proxy) ---
# Base URL of the OpenAI-compatible LLM API (no trailing slash, no /chat/completions).
# Examples: https://api.openai.com/v1  |  http://localhost:11434/v1 (Ollama)
LLM_BASE_URL=https://api.openai.com/v1

# API key forwarded as Authorization: Bearer header.
LLM_API_KEY=sk-your-key-here

# Default model name used when the client doesn't specify one.
LLM_MODEL=gpt-4o-mini

# Number of RAG chunks to retrieve per query.
RAG_TOP_K=5

# --- Open WebUI (chat interface) ---
# Port on which Open WebUI will be available (default: 3000).
# Access at http://localhost:3000 after `docker compose up`.
OPENWEBUI_PORT=3000

# URL of the FastAPI TeamRag backend that Open WebUI calls for /v1 compatibility.
# For local development (FastAPI runs on host, not in Docker):
#   - macOS/Windows: http://host.docker.internal:8000 (resolves to host machine)
#   - Linux: http://172.17.0.1:8000 or use --network="host" for docker-compose
# For production (FastAPI in Docker): http://fastapi:8000
TEAMRAG_API_URL=http://host.docker.internal:8000

# Open WebUI image version tag. Defaults to "latest" (floating tag).
# Pin to a specific release for reproducible deployments, e.g. OPENWEBUI_VERSION=v0.6.5
OPENWEBUI_VERSION=latest

# --- MCP server (Phase 4) ---
# Base URL of the TeamRag FastAPI gateway for tool handlers (POST /query, POST /document).
TEAMRAG_GATEWAY_URL=http://localhost:8000
# Default top_k when MCP tool search_knowledge does not override.
TEAMRAG_QUERY_TOP_K_DEFAULT=5
# Bind address for `teamrag-mcp --transport sse`.
MCP_SSE_HOST=127.0.0.1
MCP_SSE_PORT=8765
