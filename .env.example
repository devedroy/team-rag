# TeamRag environment configuration
# Copy this file to .env and fill in your values.

# --- Vector store (Qdrant) ---
# URL of the Qdrant HTTP API.
QDRANT_URL=http://localhost:6333

# Name of the Qdrant collection used to store document embeddings.
QDRANT_COLLECTION=teamrag

# --- Text Embeddings Inference (TEI) ---
# URL of the HuggingFace TEI server that produces embeddings.
TEI_URL=http://localhost:8080

# --- Relational database (PostgreSQL) ---
# Credentials used by the postgres Docker service and the connection URL below.
POSTGRES_USER=teamrag
POSTGRES_PASSWORD=teamrag
POSTGRES_DB=teamrag

# SQLAlchemy async connection string.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Note: DATABASE_URL must match POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB above.
# Update all four if you change credentials.
DATABASE_URL=postgresql+asyncpg://teamrag:teamrag@localhost:5432/teamrag
